# Optional: uncomment these values to use LiveKit Cloud instead of the
# development LiveKit server included in compose.yaml.
# For Docker Desktop, set this to the computer's active LAN IPv4 address.
LIVEKIT_NODE_IP=192.168.1.55
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your-livekit-api-key
# LIVEKIT_API_SECRET=your-livekit-api-secret
